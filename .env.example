# Server Configuration
PORT=3001

# QidCloud (Post-Quantum Security)
QID_API_KEY=your_qid_api_key_here
QID_TENANT_ID=your_qid_tenant_id_here

# Blockchain Configuration (opBNB Testnet)
GUARDIAN_PRIVATE_KEY=your_guardian_private_key_here
PRIVATE_KEY=your_deployer_private_key_here

# Greenfield Storage (Audit Logs)
GREENFIELD_PRIVATE_KEY=your_greenfield_private_key_here
GREENFIELD_ADDRESS=your_greenfield_address_here

# External APIs
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Frontend Environment Variables (Vite)
VITE_API_BASE=http://localhost:3001
VITE_QID_TENANT_ID=your_qid_tenant_id_here
VITE_QID_API_KEY=your_qid_api_key_here

# Contract Addresses
VITE_VAULT_ADDRESS=your_vault_address
VITE_CREDIT_MANAGER_ADDRESS=your_credit_manager_address
VITE_CREDIT_TOKEN_ADDRESS=your_credit_token_address
VITE_PRICE_ORACLE_ADDRESS=your_price_oracle_address
